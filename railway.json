{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm run build && pnpm db:push"
  },
  "deploy": {
    "startCommand": "NODE_ENV=production node dist/index.js --port=${PORT:-3000}",
    "restartPolicyMaxRetries": 5
  }
}
